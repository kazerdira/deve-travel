---
import { type Locale, t, pick, localize } from '../i18n/ui';
import { icon } from '../lib/icons';
interface Props { locale: Locale; entry: any; delay?: number; }
const { locale, entry, delay = 0 } = Astro.props;
const d = entry.data;
const href = localize(locale, `/destinations/${entry.id}`);
const d3 = `/destinations/${entry.id}-3d.png`;      // floating 3D landmark (transparent PNG)
const mesh = `mesh-${entry.id}`;                     // flag-tinted gradient (france/canada/spain/portugal)
const titleText = pick(d.title, locale).toUpperCase();
const introText = pick(d.intro, locale).replace(/\s+/g, ' ').trim();
const summaryText = introText.length > 90 ? `${introText.slice(0, 87).trimEnd()}…` : introText;
const titleColors = entry.id === 'france'
  ? ['#0055A4', '#FFFFFF', '#EF4135']
  : entry.id === 'canada'
    ? ['#D52B1E', '#FFFFFF', '#D52B1E']
    : entry.id === 'spain'
      ? ['#AA151B', '#F1BF00', '#AA151B']
      : entry.id === 'portugal'
        ? ['#006633', '#FFFFFF', '#DA291C']
        : ['var(--ember)', 'var(--ink)', 'var(--sun)'];
---
{d.available ? (
  <a class={`dcard ${mesh} card--link reveal`} data-d={String((delay % 4) + 1)} href={href}>
    <img class="dcard__art" src={d3} alt="" loading="lazy" onerror="this.remove()" />
    <div class="dcard__body">
      <h3 class={`dcard__title dcard__title--${entry.id}`}>
        {titleText.split('').map((letter, index) => (
          <span class="dcard__letter" style={`--letter-color:${titleColors[index % titleColors.length]};`}>
            {letter}
          </span>
        ))}
      </h3>
      <p class="muted small dcard__summary">{summaryText}</p>
      <span class="dcard__cta">{t(locale, 'cta.discover')} →</span>
    </div>
  </a>
) : (
  <div class={`dcard ${mesh} dcard--soon reveal`} data-d={String((delay % 4) + 1)}>
    <div class="dcard__body">
      <div class="dcard__soon-ic"><Fragment set:html={icon('plane')} /></div>
      <h3 class={`dcard__title dcard__title--${entry.id}`}>
        {titleText.split('').map((letter, index) => (
          <span class="dcard__letter" style={`--letter-color:${titleColors[index % titleColors.length]};`}>
            {letter}
          </span>
        ))}
      </h3>
      <span class="badge-soon">{t(locale, 'label.soon')}</span>
    </div>
  </div>
)}
