---
import { type Locale, pick } from '../i18n/ui';
import { getTestimonials } from '../lib/content';
interface Props { locale: Locale; destination?: string; }
const { locale, destination } = Astro.props;
const items = await getTestimonials(destination);
---
{items.length > 0 && (
  <div class="grid grid-3">
    {items.map((it, i) => (
      <figure class="quote reveal" data-d={String((i % 3) + 1)}>
        <blockquote>{pick(it.quote, locale)}</blockquote>
        <figcaption><b>{it.name}</b> · {it.city}</figcaption>
      </figure>
    ))}
  </div>
)}
