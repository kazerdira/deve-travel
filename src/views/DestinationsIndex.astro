---
import Base from '../layouts/Base.astro';
import DestinationCard from '../components/DestinationCard.astro';
import { type Locale, t } from '../i18n/ui';
import { getDestinations } from '../lib/content';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const dests = await getDestinations();
---
<Base locale={locale} title={t(locale, 'dest.title')} description={t(locale, 'dest.lede')}>
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="kicker">{t(locale, 'nav.destinations')}</span>
        <h1 class="h-1">{t(locale, 'dest.title')}</h1>
        <p class="lede">{t(locale, 'dest.lede')}</p>
      </div>
      <div class="grid grid-4">
        {dests.map((d, i) => <DestinationCard locale={locale} destination={d} delay={i} />)}
      </div>
    </div>
  </section>
</Base>
