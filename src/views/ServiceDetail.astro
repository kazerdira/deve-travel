---
import Base from '../layouts/Base.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import LeadForm from '../components/LeadForm.astro';
import { type Locale, t, pick, localize } from '../i18n/ui';
import { icon } from '../lib/icons';
import { getCollection, getEntry } from 'astro:content';
interface Props { locale: Locale; slug: string; }
const { locale, slug } = Astro.props;
const entry = await getEntry('services', slug);
if (!entry) return Astro.redirect(localize(locale, '/services'), 302);
const d = entry.data;
const dests = (await getCollection('destinations')).filter((x) => d.destinations.includes(x.id));
const related = (await getCollection('services'))
  .filter((s) => s.id !== entry.id).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const waText = pick(d.whatsapp, locale);
const seoT = d.seo ? pick(d.seo.title, locale) : pick(d.title, locale);
const seoD = d.seo ? pick(d.seo.description, locale) : pick(d.summary, locale);
const titleColors = (slug: string) => slug === 'france'
  ? ['#0055A4', '#FFFFFF', '#EF4135']
  : slug === 'canada'
    ? ['#D52B1E', '#FFFFFF', '#D52B1E']
    : slug === 'spain'
      ? ['#AA151B', '#F1BF00', '#AA151B']
      : slug === 'portugal'
        ? ['#006633', '#FFFFFF', '#DA291C']
        : ['var(--ember)', 'var(--ink)', 'var(--sun)'];
---
<Base locale={locale} title={seoT} description={seoD}>
  <section class="section" style="padding-block-start:clamp(1.5rem,4vw,2.5rem)">
    <div class="container">
      <div class="breadcrumb reveal">
        <a href={localize(locale, '/services')}>{t(locale, 'nav.services')}</a> / <span>{pick(d.title, locale)}</span>
      </div>
      <div style="max-width:64ch">
        <span class="card__ic service-card__icon reveal">
          <img src={`/icons/${entry.id}.png`} alt="" width="44" height="44" loading="lazy"
               onerror="this.style.display='none';var s=this.nextElementSibling;if(s)s.style.display='grid'" />
          <span class="ic-svg" style="display:none"><Fragment set:html={icon(d.icon)} /></span>
        </span>
        <h1 class="h-1 reveal" style="margin-block:1rem .5rem">{pick(d.title, locale)}</h1>
        <p class="lede reveal">{pick(d.tagline, locale)}</p>
        <div class="prose reveal" style="margin-block-start:1.4rem"><p>{pick(d.summary, locale)}</p></div>

        {d.includes.length > 0 && (
          <div class="reveal" style="margin-block-start:1.8rem">
            <span class="kicker">{t(locale, 'service.included')}</span>
            <ul class="check" style="margin-block-start:1rem">
              {d.includes.map((i) => <li>{pick(i, locale)}</li>)}
            </ul>
          </div>
        )}

        {dests.length > 0 && (
          <div class="reveal" style="margin-block-start:1.8rem">
            <h2 class="h-2" style="margin-block-end:.8rem">{t(locale, 'service.dest')}</h2>
            <div class="chips">
              {dests.map((x) => (
                <a class="chip" href={localize(locale, `/destinations/${x.id}`)}>
                  <span class="dcard__title chip__label">
                    {pick(x.data.title, locale).toUpperCase().split('').map((letter, index) => (
                      <span class="dcard__letter" style={`--letter-color:${titleColors(x.id)[index % titleColors(x.id).length]};`}>{letter}</span>
                    ))}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="reveal" style="margin-block-start:2rem;display:flex;flex-wrap:wrap;gap:.7rem">
          <WhatsAppButton locale={locale} text={waText} service={entry.id} />
          <a class="btn btn--ghost btn--lg" href="#devis"><Fragment set:html={icon('pen')} /> {t(locale, 'cta.quote')}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--sand">
    <div class="container">
      <div class="section-head reveal"><h2 class="h-2">{t(locale, 'service.related')}</h2></div>
      <div class="grid grid-3">
        {related.map((s, i) => (
          <a class="card card--link service-card reveal" data-d={String((i % 3) + 1)} href={localize(locale, `/services/${s.id}`)}>
            <span class="card__ic service-card__icon">
              <img src={`/icons/${s.id}.png`} alt="" width="44" height="44" loading="lazy"
                   onerror="this.style.display='none';var s=this.nextElementSibling;if(s)s.style.display='grid'" />
              <span class="ic-svg" style="display:none"><Fragment set:html={icon(s.data.icon)} /></span>
            </span>
            <h3>{pick(s.data.title, locale)}</h3>
            <p class="muted small" style="margin-block-start:.5rem">{pick(s.data.tagline, locale)}</p>
            <span class="card__cta">{t(locale, 'cta.info')} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dusk" id="devis">
    <div class="container" style="display:grid;gap:2rem;max-width:700px">
      <div class="reveal">
        <span class="kicker">{t(locale, 'cta.quote')}</span>
        <h2 class="h-1" style="margin-block:.7rem .5rem">{t(locale, 'form.title')}</h2>
        <p style="opacity:.9">{t(locale, 'contact.lede')}</p>
      </div>
      <div class="card--form reveal" data-d="1"><LeadForm locale={locale} service={entry.id} /></div>
    </div>
  </section>
</Base>
