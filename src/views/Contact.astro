---
import Base from '../layouts/Base.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import LeadForm from '../components/LeadForm.astro';
import { type Locale, t } from '../i18n/ui';
import { icon } from '../lib/icons';
import { SITE } from '../consts';
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<Base locale={locale} title={t(locale, 'contact.title')} description={t(locale, 'contact.lede')}>
  <section class="section">
    <div class="container" style="display:grid;gap:2.5rem;grid-template-columns:1fr">
      <div style="max-width:52ch" class="reveal">
        <span class="kicker">{t(locale, 'nav.contact')}</span>
        <h1 class="h-1" style="margin-block:.6rem .5rem">{t(locale, 'contact.title')}</h1>
        <p class="lede">{t(locale, 'contact.lede')}</p>
        <div style="margin-block-start:1.4rem;display:flex;flex-direction:column;gap:.7rem;max-width:340px">
          <WhatsAppButton locale={locale} service="contact" block={true} />
          <a class="btn btn--ghost btn--block btn--lg" href={`tel:${SITE.whatsapp}`} data-call>
            <Fragment set:html={icon('phone')} /> {SITE.phoneDisplay}
          </a>
        </div>
        <div style="margin-block-start:1.8rem">
          <h2 class="h-2" style="font-size:1.1rem">{t(locale, 'contact.hours')}</h2>
          <p class="muted">{SITE.hours}</p>
          <a class="address-link" href="https://www.google.com/maps/place//data=!4m2!3m1!1s0x12f2ddcbc6b08281:0xedfdbedee71ae82?sa=X&ved=1t:8290&ictx=111" target="_blank" rel="noopener noreferrer">
            [ Souk El-Thenine 06012, Algérie ]
          </a>
        </div>
      </div>
      <div class="card--form reveal" data-d="1" style="max-width:640px;width:100%">
        <h2 class="h-2" style="margin-block-end:1rem">{t(locale, 'form.title')}</h2>
        <LeadForm locale={locale} />
      </div>
    </div>
  </section>
</Base>
