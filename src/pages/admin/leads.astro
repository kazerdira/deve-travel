---
import Admin from '../../layouts/Admin.astro';
import { listLeads } from '../../lib/admin';
export const prerender = false;
const leads = await listLeads(200);
const STATUSES = ['new', 'contacted', 'won', 'lost'];
const LABEL: Record<string, string> = { new: 'nouveau', contacted: 'contacté', won: 'gagné', lost: 'perdu' };
const waLink = (phone: string) => {
  const digits = (phone ?? '').replace(/[^\d]/g, '');
  return digits ? `https://wa.me/${digits}` : null;
};
const fmt = (d: Date) => new Date(d).toLocaleString('fr-FR', { dateStyle: 'short', timeStyle: 'short' });
---
<Admin title="Leads" active="leads">
  <div class="admin-head">
    <h1>Leads <span class="muted" style="font-size:1rem">({leads.length} derniers)</span></h1>
    <a class="btn btn--ink btn--sm" href="/api/admin/leads-csv">Exporter CSV</a>
  </div>
  <div class="tbl-scroll">
    <table class="tbl">
      <thead>
        <tr><th>Date</th><th>Nom</th><th>Téléphone</th><th>Destination</th><th>Service</th><th>Offre</th><th>Statut</th><th></th></tr>
      </thead>
      <tbody>
        {leads.length === 0 && <tr><td colspan="8" class="muted">Aucun lead pour l’instant.</td></tr>}
        {leads.map((l: any) => (
          <tr>
            <td class="muted">{fmt(l.created_at)}</td>
            <td><b>{l.name}</b>{l.message && <div class="muted" style="max-width:26ch;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title={l.message}>{l.message}</div>}</td>
            <td>{l.phone}</td>
            <td>{l.destination ?? '—'}</td>
            <td>{l.service ?? '—'}</td>
            <td>{l.offer_slug ?? '—'}</td>
            <td>
              <form method="post" action="/api/admin/leads">
                <input type="hidden" name="id" value={l.id} />
                <select name="status" onchange="this.form.submit()">
                  {STATUSES.map((s) => <option value={s} selected={l.status === s}>{LABEL[s]}</option>)}
                </select>
                <noscript><button class="btn btn--sm btn--ghost" type="submit">OK</button></noscript>
              </form>
            </td>
            <td>
              {waLink(l.phone) && <a class="btn btn--wa btn--sm" href={waLink(l.phone)} target="_blank" rel="noopener">Ouvrir WhatsApp</a>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Admin>
