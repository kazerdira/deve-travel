# --- public site config (dev-safe fallbacks exist for all of these) ---
PUBLIC_AGENCY_NAME=Deve Travel
PUBLIC_AGENCY_CITY=Alger
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_WHATSAPP_NUMBER=213770000000
PUBLIC_PHONE_DISPLAY=+213 770 00 00 00
PUBLIC_FB_URL=https://facebook.com/
PUBLIC_IG_URL=https://instagram.com/
PUBLIC_HOURS=Dim–Jeu · 9h00–17h00

# --- backend ---
# Required for content (destinations, services, offers, testimonials).
# Example: postgresql://postgres:devpass@localhost:5432/deve
DATABASE_URL=

# Hashes visitor IPs + signs the admin session cookie. Use a long random string.
APP_SALT=change-me

# Single admin password for /admin.
ADMIN_PASSWORD=change-me

# Where admin image uploads are written. On Railway: /data/uploads (mounted volume).
UPLOAD_DIR=./public/uploads

# --- Telegram bot (optional; bot silently disabled if unset) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Daily digest hour (0-23, server-local time). Leave unset for no digest.
TELEGRAM_DIGEST_HOUR=
