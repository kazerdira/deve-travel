# --- public site config (dev-safe fallbacks exist for all of these) ---
PUBLIC_AGENCY_NAME=Deve Travel
PUBLIC_AGENCY_CITY=Alger
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_WHATSAPP_NUMBER=213770000000
PUBLIC_PHONE_DISPLAY=+213 770 00 00 00
PUBLIC_FB_URL=https://facebook.com/
PUBLIC_IG_URL=https://instagram.com/
PUBLIC_HOURS=Dim–Jeu · 9h00–17h00

# --- backend ---
DATABASE_URL=                 # required for content (destinations, services, offers, testimonials)
APP_SALT=change-me            # hashes visitor IPs + signs the admin session cookie
ADMIN_PASSWORD=change-me      # single admin password for /admin
UPLOAD_DIR=./public/uploads   # on Railway: /data/uploads (mounted volume)

# --- Telegram bot (optional; bot silently disabled if unset) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_DIGEST_HOUR=20       # optional, 0-23, server-local time; unset = no daily digest
